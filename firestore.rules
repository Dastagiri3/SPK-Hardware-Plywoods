rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role, createdAt
    //
    // Collection: companies
    // Fields: name, slug, logoUrl, description, website, isFeatured
    //
    // Collection: categories
    // Fields: name, slug, parentId, iconUrl
    //
    // Collection: products
    // Fields: companyId, categoryId, name, sku, description, price, unit, stockQty, images, specs, isActive
    //
    // Collection: catalogs
    // Fields: companyId, title, fileUrl, uploadedAt, version, pageCount
    //
    // Collection: orders
    // Fields: userId, status, items, totalAmount, deliveryAddress, createdAt
    //
    // Collection: quotes
    // Fields: userId, items, message, status, adminNotes, createdAt
    //
    // Collection: designSuggestions
    // Fields: userId, imageUrl, budget, roomType, suggestionText, interiorOptions, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "gurudastagiri3@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'admin', 'staff'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['companyId', 'categoryId', 'name', 'price']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'status', 'items', 'totalAmount']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'dispatched', 'delivered'];
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['userId', 'items', 'status']) &&
             data.userId == request.auth.uid &&
             data.status in ['new', 'in-review', 'sent', 'won', 'lost'];
    }

    function isValidDesignSuggestion(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'budget']) &&
             data.userId == request.auth.uid &&
             data.budget is number && data.budget > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /companies/{companyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /catalogs/{catalogId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidQuote(request.resource.data);
      allow update: if isAdmin();
    }

    match /designSuggestions/{suggestionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidDesignSuggestion(request.resource.data);
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
